<Window x:Class="finance_tracker_comp586.views.TransactionInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:clearableTextBox="clr-namespace:finance_tracker_comp586.views.user_controls"
        Title="Transaction" SizeToContent="Height" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" FontSize="16">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="DarkRed" Offset="0"/>
            <GradientStop Color="DarkOrange" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkRed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormInputStyle" TargetType="Control">
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <StaticResource ResourceKey="BackgroundGradient"/>
    </Window.Background>

    <Grid>
        <Border Background="White" CornerRadius="15" Padding="30" Margin="10"
                Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Transaction Details" Foreground="DarkRed" FontSize="16"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Category" Foreground="Gray" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CategoryComboBox" Style="{StaticResource FormInputStyle}" SelectedIndex="0">
                        <ComboBoxItem Content="Food"/>
                        <ComboBoxItem Content="Utilities"/>
                        <ComboBoxItem Content="Rent"/>
                        <ComboBoxItem Content="Transportation"/>
                        <ComboBoxItem Content="Entertainment"/>
                        <ComboBoxItem Content="Income"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Date" Foreground="Gray" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="MonthComboBox" Style="{StaticResource FormInputStyle}" SelectedIndex="0" Margin="0,0,5,0">
                            <ComboBoxItem Content="January"/>
                            <ComboBoxItem Content="February"/>
                            <ComboBoxItem Content="March"/>
                            <ComboBoxItem Content="April"/>
                            <ComboBoxItem Content="May"/>
                            <ComboBoxItem Content="June"/>
                            <ComboBoxItem Content="July"/>
                            <ComboBoxItem Content="August"/>
                            <ComboBoxItem Content="September"/>
                            <ComboBoxItem Content="October"/>
                            <ComboBoxItem Content="November"/>
                            <ComboBoxItem Content="December"/>
                        </ComboBox>
                        <ComboBox Grid.Column="1" x:Name="DayComboBox" Style="{StaticResource FormInputStyle}" SelectedIndex="0" Margin="0,0,5,0">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="31"/>
                        </ComboBox>
                        <ComboBox Grid.Column="2" x:Name="YearComboBox" Style="{StaticResource FormInputStyle}" SelectedIndex="2">
                            <ComboBoxItem Content="2024"/>
                            <ComboBoxItem Content="2025"/>
                            <ComboBoxItem Content="2026"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Amount" Foreground="Gray" Margin="0,0,0,5"/>
                    <clearableTextBox:ClearableTextBox x:Name="AmountInputBox"
                                                       Height="35" HorizontalAlignment="Left"
                                                       BorderBrush="LightGray" BorderThickness="1"
                                                       Placeholder="0.00"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Description" Foreground="Gray" Margin="0,0,0,5"/>
                    <clearableTextBox:ClearableTextBox x:Name="DescriptionInputBox"
                                                       Height="35" HorizontalAlignment="Left"
                                                       BorderBrush="LightGray" BorderThickness="1"
                                                       Placeholder="What was this for?"/>
                </StackPanel>

                <UniformGrid Columns="2">
                    <Button Content="Cancel" Style="{StaticResource RedButtonStyle}"
                            Background="#EEEEEE" Foreground="DimGray"
                            Margin="0,0,5,0" Click="Cancel_Button_Click"/>
                    <Button Content="Confirm" Style="{StaticResource RedButtonStyle}"
                            Margin="5,0,0,0" Click="Confirm_Button_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
