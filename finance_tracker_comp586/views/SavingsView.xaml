<Page x:Class="finance_tracker_comp586.views.SavingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Savings">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>

        <LinearGradientBrush x:Key="SavingsBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="DarkRed" Offset="0"/>
            <GradientStop Color="DarkOrange" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkRed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Page.Resources>

    <Page.Background>
        <StaticResource ResourceKey="SavingsBackground"/>
    </Page.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Text="Savings" Foreground="White" 
                   FontSize="32" Margin="8,0,0,15"/>

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Content="Home" Style="{StaticResource WhiteButtonStyle}"
                    Margin="5" Click="Home_Button_Click"/>
            <Button Content="Log Off" Style="{StaticResource WhiteButtonStyle}"
                    Margin="5" Click="LogOff_Button_Click"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Current Amount" FontSize="16" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" Style="{StaticResource RedButtonStyle}" Margin="0,0,5,0" Click="Add_Button_Click"/>
                        <Button Content="-" Style="{StaticResource RedButtonStyle}" Click="Subtract_Button_Click"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding Balance, StringFormat={}{0:C}}" 
                           FontSize="16" Foreground="Black"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Current APY" FontSize="16" Foreground="Gray"/>
                    <Button Content="Edit" Style="{StaticResource RedButtonStyle}" HorizontalAlignment="Right" Click="Edit_Button_Click"/>
                </Grid>
                <TextBlock Text="{Binding APY, StringFormat={}{0:P2}}" 
                           FontSize="16" Foreground="Black"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Interest Earned" FontSize="16" Foreground="Gray" Margin="0,0,0,10"/>

                <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                    <TabItem Header="Month">
                        <TextBlock Text="{Binding InterestEarnedMonth, StringFormat={}{0:C}}" 
                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"/>
                    </TabItem>
                    <TabItem Header="Year">
                        <TextBlock Text="{Binding InterestEarnedYear, StringFormat={}{0:C}}" 
                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"/>
                    </TabItem>
                    <TabItem Header="Lifetime">
                        <TextBlock Text="{Binding InterestEarnedLifetime, StringFormat={}{0:C}}" 
                                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Page>