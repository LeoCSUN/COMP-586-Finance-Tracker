<Page x:Class="finance_tracker_comp586.views.SavingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Savings"
      x:Name="Self">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <LinearGradientBrush x:Key="SavingsBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="DarkRed" Offset="0"/>
            <GradientStop Color="DarkOrange" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkRed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="RangeToggleStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="5" Padding="8,4" Background="Transparent">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="DarkRed"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="Bd" Property="Background" Value="#FFEEEEF0"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.Background>
        <StaticResource ResourceKey="SavingsBackground"/>
    </Page.Background>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Text="Savings" Foreground="White" 
                   FontSize="32" Margin="8,0,0,15"/>

        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Text="{Binding FullName, ElementName=Self}" FontSize="16" Foreground="White" Margin="0,0,30,0" VerticalAlignment="Center"/>
            <Button Content="Home" Style="{StaticResource WhiteButtonStyle}"
                    Margin="5" Click="Home_Button_Click"/>
            <Button Content="Log Off" Style="{StaticResource WhiteButtonStyle}"
                    Margin="5" Click="LogOff_Button_Click"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Current Amount" FontSize="16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" Style="{StaticResource RedButtonStyle}" Margin="0,0,5,0" Click="Add_Button_Click"/>
                        <Button Content="-" Style="{StaticResource RedButtonStyle}" Click="Subtract_Button_Click"
                                Visibility="{Binding HasBalance, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding Balance, StringFormat={}{0:C}}" 
                           FontSize="32" Foreground="Black"
                           Visibility="{Binding HasBalance, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="No balance, make your first deposit on the top right"
                           FontSize="14"  TextWrapping="Wrap"
                           Visibility="{Binding HasNoBalance, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Current APY" FontSize="16" />
                    <Button Content="Edit" Style="{StaticResource RedButtonStyle}" HorizontalAlignment="Right" Click="Edit_Button_Click"/>
                </Grid>
                <TextBlock Text="{Binding APY, StringFormat={}{0:0.##}%}" 
                           FontSize="32" Foreground="Black"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Interest Earned" FontSize="16"  Margin="0,0,0,10"/>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton Content="Month"    GroupName="InterestRangeGroup" IsChecked="True" Tag="Month"    Style="{StaticResource RangeToggleStyle}" Checked="InterestRange_Checked"/>
                    <RadioButton Content="Year"     GroupName="InterestRangeGroup" Tag="Year"     Style="{StaticResource RangeToggleStyle}" Checked="InterestRange_Checked"/>
                    <RadioButton Content="Lifetime" GroupName="InterestRangeGroup" Tag="Lifetime" Style="{StaticResource RangeToggleStyle}" Checked="InterestRange_Checked"/>
                </WrapPanel>

                <lvc:CartesianChart Grid.Row="2" x:Name="InterestChart" MinHeight="150" LegendPosition="Hidden"/>
            </Grid>
        </Border>
    </Grid>
</Page>