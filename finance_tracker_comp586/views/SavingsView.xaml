<Page x:Class="finance_tracker_comp586.views.SavingsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Savings">
    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>
        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <LinearGradientBrush x:Key="SavingsBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="DarkRed" Offset="0"/>
            <GradientStop Color="DarkOrange" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>
    <Page.Background>
        <StaticResource ResourceKey="SavingsBackground"/>
    </Page.Background>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Savings" Foreground="{StaticResource PrimaryWhite}" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" Content="Home" Style="{StaticResource WhiteButtonStyle}" HorizontalAlignment="Right" Click="Home_Button_Click"/>
        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <TextBlock Text="Current Amount" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" Style="{StaticResource RedButtonStyle}" Click="Add_Button_Click"/>
                        <Button Content="-" Style="{StaticResource RedButtonStyle}" Click="Subtract_Button_Click"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Balance, StringFormat=$ {0:F2}}" FontSize="32" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <TextBlock Text="Current APY" FontSize="16"/>
                    <Button Grid.Column="1" Content="Edit" Style="{StaticResource RedButtonStyle}" HorizontalAlignment="Right" Click="Edit_Button_Click"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding APY, StringFormat=% {0:F2}}" FontSize="32" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Interest Earned" FontSize="16"/>
                <TabControl TabStripPlacement="Top" Margin="5">
                    <TabItem Header="Month">
                        <Label Content="{Binding InterestEarnedMonth, StringFormat=$ {0:F2}}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </TabItem>
                    <TabItem Header="Year">
                        <Label Content="{Binding InterestEarnedYear, StringFormat=$ {0:F2}}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </TabItem>
                    <TabItem Header="Lifetime">
                        <Label Content="{Binding InterestEarnedLifetime, StringFormat=$ {0:F2}}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Border>
    </Grid>
</Page>