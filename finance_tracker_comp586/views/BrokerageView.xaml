<Page x:Class="finance_tracker_comp586.views.BrokerageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      xmlns:uc="clr-namespace:finance_tracker_comp586.views.user_controls"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Brokerage">

    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>

        <!-- Button Styles -->
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        

        <!-- Background Gradient -->
        <LinearGradientBrush x:Key="BrokerageBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>

    <Page.Background>
        <StaticResource ResourceKey="BrokerageBackground"/>
    </Page.Background>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Brokerage"
                   Foreground="{StaticResource PrimaryWhite}"
                   FontSize="32"
                   Margin="5"
                   HorizontalAlignment="Left"/>

        <Button Grid.Row="0"
                Grid.Column="1"
                Content="Home"
                Style="{StaticResource WhiteButtonStyle}"
                HorizontalAlignment="Right"
                Click="Home_Button_Click"/>

        <!-- Owned Stocks -->
        <Border Grid.Row="1"
                BorderBrush="Transparent"
                Margin="5"
                Padding="10"
                CornerRadius="5"
                Background="{StaticResource PrimaryWhite}">

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Portfolio" FontSize="16" Margin="0,0,0,10"/>

                <ListView x:Name="OwnedStocksListBox">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Symbol" DisplayMemberBinding="{Binding Stock.Symbol}" Width="100"/>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Stock.Name}" Width="150"/>
                            <GridViewColumn Header="Shares" DisplayMemberBinding="{Binding Shares}" Width="100"/>
                            <GridViewColumn Header="Avg Price" DisplayMemberBinding="{Binding AvgPrice}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <!-- Price Graph -->
        <Border Grid.Row="1"
                Grid.Column="1"
                BorderBrush="Transparent"
                Margin="5"
                Padding="10"
                CornerRadius="5"
                Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Price Graph" FontSize="16"/>
                <!-- LiveCharts placeholder -->
            </StackPanel>
        </Border>

        <!-- Market Search -->
        <Border Grid.Row="2"
                BorderBrush="Transparent"
                Margin="5"
                Padding="10"
                CornerRadius="5"
                Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">

                <TextBlock Text="Market" FontSize="16" Margin="0,0,0,10"/>

                <!-- Search Bar -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <uc:ClearableTextBox x:Name="StockSearchBox"
                                         Width="200"
                                         Placeholder="Enter symbol (e.g. AAPL)"
                                         KeyDown="StockSearchBox_KeyDown"/>

                    <Button Content="Search"
                            Style="{StaticResource RedButtonStyle}"
                            Margin="10,0,0,0"
                            Click="SearchStock_Click"/>
                </StackPanel>

                <!-- Search Results Table -->
                <ListView x:Name="SearchResultsListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Symbol" DisplayMemberBinding="{Binding Symbol}" Width="100"/>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150"/>
                            <GridViewColumn Header="Price" DisplayMemberBinding="{Binding Price}" Width="100"/>
                            <GridViewColumn Header="Change" DisplayMemberBinding="{Binding Change}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>

            </StackPanel>
        </Border>

        <!-- Portfolio Diversification -->
        <Border Grid.Row="2"
                Grid.Column="1"
                BorderBrush="Transparent"
                Margin="5"
                Padding="10"
                CornerRadius="5"
                Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Portfolio Diversification" FontSize="16"/>
                <Grid x:Name="PieChartContainer"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>