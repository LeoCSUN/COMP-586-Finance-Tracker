<Window x:Class="finance_tracker_comp586.views.AmountInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:clearableTextBox="clr-namespace:finance_tracker_comp586.views.user_controls"
        Title="Enter Amount"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <!-- Resources -->
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>

        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
        </Style>

        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Background>
        <StaticResource ResourceKey="BackgroundGradient"/>
    </Window.Background>

    <!-- CENTERED CARD -->
    <Grid>
        <Border Background="{StaticResource PrimaryWhite}"
                CornerRadius="8"
                Padding="20"
                Width="260"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- Label -->
                <TextBlock Text="Enter Amount"
                           FontSize="16"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <!-- Input -->
                <clearableTextBox:ClearableTextBox x:Name="InputTextBox" Placeholder="0.00" Width="200" Margin="0,0,0,15"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Confirm" Style="{StaticResource RedButtonStyle}" Click="Confirm_Button_Click"/>
                    <Button Content="Cancel" Style="{StaticResource RedButtonStyle}" Click="Cancel_Button_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>