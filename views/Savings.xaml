<Page x:Class="finance_tracker_comp586.views.Savings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Savings">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Savings" Foreground="White" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Content="Home" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Home_Button_Click"/>

        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Current Amount" FontSize="16"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Balance, StringFormat=$ {0:F2}}" FontSize="32" Width="250"/>
                    <Button Content="+" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed"/>
                    <Button Content="-" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Current APY" FontSize="16"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding APY, StringFormat=% {0:F2}}" FontSize="32" Width="100"/>
                    <Button Content="Edit" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Interest Earned" FontSize="16"/>
                <Grid>
                    <TabControl TabStripPlacement="Top" Margin="5">
                        <TabItem Header="Month">
                            <Label Content="{Binding InterestEarnedMonth, StringFormat=$ {0:F2}}" FontSize="32"/>
                        </TabItem>
                        <TabItem Header="Year">
                            <Label Content="{Binding InterestEarnedYear, StringFormat=$ {0:F2}}" FontSize="32"/>
                        </TabItem>
                        <TabItem Header="Lifetime">
                            <Label Content="{Binding InterestEarnedLifetime, StringFormat=$ {0:F2}}" FontSize="32"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
