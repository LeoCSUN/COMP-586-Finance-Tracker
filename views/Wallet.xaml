<Page x:Class="finance_tracker_comp586.views.Wallet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Wallet">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Margin="5">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Wallet" Foreground="White" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Content="Home" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Home_Button_Click"/>

        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Current Amount" FontSize="16"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentAmount, StringFormat=$ {0:F2}}" FontSize="32" Width="225"/>
                    <Button Content="+" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    <Button Content="-" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">

                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <TextBlock Text="Budget - Month" FontSize="16"/>
                    <TextBlock FontSize="16">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="$ {0:F2} / {1:F2}">
                                <Binding Path="AmountSpentMonth"/>
                                <Binding Path="MonthlyBudget"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Button Content="Edit" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Transactions" FontSize="16"/>

                <Button Content="Add Transaction" Width="120" Height="25" Margin="5"
                BorderBrush="Transparent" Foreground="White" Background="DarkRed"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>

                <ListView ItemsSource="{Binding Transactions}" VerticalAlignment="Stretch">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding TransactionDate}"/>
                            <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Amount" DisplayMemberBinding="{Binding Amount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <TextBlock Text="pie chart will go here" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>
