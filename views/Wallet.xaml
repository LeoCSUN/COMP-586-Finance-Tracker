<Page x:Class="finance_tracker_comp586.views.Wallet"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:finance_tracker_comp586.views" mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1000" Title="Wallet"
      xmlns:clearableTextBox="clr-namespace:finance_tracker_comp586.views.user_controls">
    <!-- Resources -->
    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>
        <!-- Red Buttons -->
        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- White Home Button Style (like Brokerage) -->
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Gradient Background -->
        <LinearGradientBrush x:Key="WalletBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>
    <!-- Page Background -->
    <Page.Background>
        <StaticResource ResourceKey="WalletBackground"/>
    </Page.Background>
    <!-- Main Grid -->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Wallet" Foreground="{StaticResource PrimaryWhite}" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" Content="Home" Style="{StaticResource WhiteButtonStyle}" HorizontalAlignment="Right" Click="Home_Button_Click"/>
        <!-- Current Amount Section -->
        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <TextBlock Text="Current Amount" FontSize="16"/>
                    <StackPanel x:Name="AddSubtractButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" Style="{StaticResource RedButtonStyle}" Click="Add_Button_Click"/>
                        <Button Content="-" Style="{StaticResource RedButtonStyle}" Click="Subtract_Button_Click"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding CurrentAmount, StringFormat=$ {0:F2}}" FontSize="32" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
        <!-- Budget Section -->
        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical" Margin="0,5">
                <Grid>
                    <TextBlock Text="Monthly Budget" FontSize="16"/>
                    <Button Content="Edit" Style="{StaticResource RedButtonStyle}" HorizontalAlignment="Right" Click="Edit_Button_Click"/>
                </Grid>
                <TextBlock FontSize="16">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="$ {0:F2} / {1:F2}">
                            <Binding Path="AmountSpentMonth"/>
                            <Binding Path="MonthlyBudget"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
        <!-- Pie Chart Placeholder -->
        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <TextBlock Text="Pie chart will go here" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <!-- Transactions Section -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <Grid>
                    <TextBlock Text="Transactions" FontSize="16"/>
                    <Button Content="Add Transaction" Width="120" Height="25" Style="{StaticResource RedButtonStyle}" HorizontalAlignment="Right" Click="Add_Transaction_Button_Click"/>
                </Grid>
                <ListView ItemsSource="{Binding Transactions}" VerticalAlignment="Stretch">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding TransactionDate}"/>
                            <GridViewColumn Header="Amount" DisplayMemberBinding="{Binding Amount}"/>
                            <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>