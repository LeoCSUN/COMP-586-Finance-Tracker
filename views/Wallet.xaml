<Page x:Class="finance_tracker_comp586.views.Wallet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Wallet"
      Background="DarkRed">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Wallet" Foreground="White" FontSize="32" Margin="5"/>

        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Current Amount" FontSize="16"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="$ 0.00" FontSize="32" Width="250"/>
                    <Button Content="+" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed"/>
                    <Button Content="-" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">

                <StackPanel Grid.Row="1" Orientation="Vertical">
                    <TextBlock Text="Budget - Month" FontSize="16"/>
                    <TextBlock Text="$ 0.00 / 100.00" FontSize="16"/>
                    <Button Content="Edit" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,20,0,0">
                    <TextBlock Text="Budget - Year" FontSize="16"/>
                    <TextBlock Text="$ 0.00 / 100.00" FontSize="16"/>
                    <Button Content="Edit" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Foreground="White" Background="DarkRed" HorizontalAlignment="Left"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <Border Grid.Row="3" Grid.ColumnSpan="2"  BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Transactions" FontSize="16"/>
                <TextBlock Text="transactions list will go here" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <TextBlock Text="pie chart will go here" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>
