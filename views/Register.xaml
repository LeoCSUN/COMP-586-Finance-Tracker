<Page x:Class="finance_tracker_comp586.views.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      xmlns:clearableTextBox="clr-namespace:finance_tracker_comp586.views.user_controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Register">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="Register" Foreground="White" FontSize="32" Margin="5"/>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Username" Width="75" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                <clearableTextBox:ClearableTextBox Height="30" Width="250" Placeholder="username" Loaded="ClearableTextBox_Loaded"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Password" Width="75" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                <clearableTextBox:ClearableTextBox Height="30" Width="250" Placeholder="password"/>
            </StackPanel>
            <Grid>
                <Button Content="Register" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

    </Grid>
</Page>
