<Page x:Class="finance_tracker_comp586.views.Brokerage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Brokerage">
    <!-- Resources -->
    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryRed" Color="DarkRed"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBlack" Color="Black"/>
        <!-- Button Style -->
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlack}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Gradient Background -->
        <LinearGradientBrush x:Key="BrokerageBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>
    <!-- Page Background -->
    <Page.Background>
        <StaticResource ResourceKey="BrokerageBackground"/>
    </Page.Background>
    <!-- Main Grid -->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Upper Sections -->
            <RowDefinition Height="*"/>
            <!-- Lower Sections -->
        </Grid.RowDefinitions>
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Brokerage" Foreground="{StaticResource PrimaryWhite}" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" Content="Home" Style="{StaticResource WhiteButtonStyle}" HorizontalAlignment="Right" Click="Home_Button_Click"/>
        <!-- Owned Stocks Section -->
        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Owned Stocks" FontSize="16"/>
                <!-- Add stock list or controls here -->
            </StackPanel>
        </Border>
        <!-- Price Graph Section -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Price Graph" FontSize="16"/>
                <!-- Add chart control here -->
            </StackPanel>
        </Border>
        <!-- Market Search Section -->
        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Market Search" FontSize="16"/>
                <!-- Add search controls here -->
            </StackPanel>
        </Border>
        <!-- Pie Chart Section -->
        <Border Grid.Row="2" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="{StaticResource PrimaryWhite}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Portfolio Pie Chart" FontSize="16"/>
                <!-- Add pie chart here -->
            </StackPanel>
        </Border>
    </Grid>
</Page>