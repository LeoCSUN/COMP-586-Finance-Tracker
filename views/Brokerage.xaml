<Page x:Class="finance_tracker_comp586.views.Brokerage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:finance_tracker_comp586.views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Brokerage">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Brokerage" Foreground="White" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Content="Home" Width="50" Height="25" Margin="5" BorderBrush="Transparent" Background="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Home_Button_Click"/>
        
        <!-- OWNED STOCKS -->
        <Border Grid.Row="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
            </StackPanel>
        </Border>

        <!-- MARKET SEARCH -->
        <Border Grid.Row="2" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
            </StackPanel>
        </Border>

        <!-- PRICE GRAPH -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
            </StackPanel>
        </Border>

        <!-- PIE CHART -->
        <Border Grid.Row="2" Grid.Column="1" BorderBrush="Transparent" Margin="5" Padding="10" CornerRadius="5" Background="White">
            <StackPanel Orientation="Vertical">
            </StackPanel>
        </Border>

    </Grid>
</Page>
