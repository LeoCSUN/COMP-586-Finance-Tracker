<Page x:Class="finance_tracker_comp586.views.Login"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:finance_tracker_comp586.views"
	xmlns:clearableTextBox="clr-namespace:finance_tracker_comp586.views.user_controls"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1000"
      Title="Login">
    <!-- Resources -->
    <Page.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryOrange" Color="Orange"/>
        <SolidColorBrush x:Key="PrimaryWhite" Color="White"/>
        <!-- Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryWhite}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryOrange}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Gradient Background -->
        <LinearGradientBrush x:Key="LoginBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9B111E" Offset="0"/>
            <GradientStop Color="#964B00" Offset="1"/>
        </LinearGradientBrush>
    </Page.Resources>
    <!-- Page Background -->
    <Page.Background>
        <StaticResource ResourceKey="LoginBackground"/>
    </Page.Background>
    <!-- Main Grid -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Form -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <!-- Header -->
        <TextBlock Grid.Column="0" Text="Login" Foreground="White" FontSize="32" Margin="5" HorizontalAlignment="Left"/>
        <!-- Form Section -->
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                    <clearableTextBox:ClearableTextBox x:Name="UsernameTextBox" Placeholder="Username" Height="30" Width="250" IsPassword="False"/>
                </StackPanel>
            </Grid>
            <!-- Password -->
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                    <clearableTextBox:ClearableTextBox x:Name="PasswordTextBox" Placeholder="Password" Height="30" Width="250" IsPassword="True"/>
                </StackPanel>
            </Grid>
            <!-- Register Button -->
            <Button Content="Login" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Click="Login_Button_Click"/>
            <Button Content="Register for an Account" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Click="Register_Button_Click"/>
        </StackPanel>
    </Grid>
</Page>