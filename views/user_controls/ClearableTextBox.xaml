<UserControl x:Class="finance_tracker_comp586.views.user_controls.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finance_tracker_comp586.views.user_controls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="200">
    <Grid Background="White">
        <TextBlock Name="textPlaceholder" Text="{Binding Placeholder}" FontSize="16" FontWeight="Light" Foreground="DarkGray" VerticalAlignment="Center" Margin="5"/>
        <TextBox Name="textInput" VerticalContentAlignment="Center" FontSize="16" FontWeight="Light" Background="Transparent" TextChanged="textInput_TextChanged" BorderBrush="Transparent" MaxLength="20"/>
        <Button Name="buttonClear" HorizontalAlignment="Right" Width="25" Content="X" Background="Transparent" Foreground="LightGray" BorderThickness="0" Click="buttonClear_Click"/>
    </Grid>
</UserControl>
