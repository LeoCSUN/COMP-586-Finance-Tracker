<UserControl x:Class="finance_tracker_comp586.views.user_controls.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="30" Width="250"
             Loaded="UserControl_Loaded">
    <Grid Background="White">
        <!-- Placeholder -->
        <TextBlock x:Name="textPlaceholder"
                   Text="Placeholder"
                   FontSize="16"
                   FontWeight="Light"
                   Foreground="DarkGray"
                   VerticalAlignment="Center"
                   Margin="5"
                   IsHitTestVisible="False"/>

        <!-- Normal TextBox -->
        <TextBox x:Name="textInput"
                 TextChanged="textInput_TextChanged"
                 VerticalContentAlignment="Center"
                 FontSize="16"
                 FontWeight="Light"
                 Background="Transparent"
                 BorderBrush="Transparent"
                 MaxLength="50"/>

        <!-- PasswordBox -->
        <PasswordBox x:Name="passwordInput"
                     PasswordChanged="passwordInput_PasswordChanged"
                     VerticalContentAlignment="Center"
                     FontSize="16"
                     FontWeight="Light"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     MaxLength="50"
                     Visibility="Collapsed"/>

        <!-- Clear button -->
        <Button x:Name="buttonClear"
                Content="X"
                Width="25"
                Background="Transparent"
                Foreground="LightGray"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="buttonClear_Click"/>
    </Grid>
</UserControl>